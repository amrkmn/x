{
    "name": "x",
    "version": "0.0.1",
    "description": "Mihon & Aniyomi Extensions",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "astro dev",
        "build": "bun run data:generate && astro build",
        "preview": "astro preview",
        "check": "astro check",
        "format": "prettier --write .",
        "lint": "prettier --check .",
        "update": "bun run scripts/task.ts full",
        "update:check": "bun run scripts/task.ts check",
        "update:static": "bun run scripts/task.ts static",
        "data:generate": "bun run scripts/task.ts data",
        "search:update": "bun run scripts/task.ts search",
        "cache:restore": "bun run scripts/task.ts cache restore",
        "cache:save": "bun run scripts/task.ts cache save",
        "prepare:dist": "bun run scripts/task.ts prepare-dist",
        "sync": "bun run update:static",
        "test": "bun test",
        "setup-hooks": "bun run scripts/setup-hooks.ts"
    },
    "devDependencies": {
        "@astrojs/check": "^0.9.9",
        "@astrojs/svelte": "^8.1.1",
        "@aws-sdk/client-s3": "^3.1048.0",
        "@aws-sdk/lib-storage": "^3.1048.0",
        "@types/bun": "^1.3.14",
        "astro": "^6.3.3",
        "meilisearch": "^0.54.0",
        "minisearch": "^7.2.0",
        "prettier": "^3.8.3",
        "prettier-plugin-astro": "^0.14.1",
        "prettier-plugin-svelte": "^3.5.2",
        "svelte": "^5.55.7",
        "typescript": "^5.9.3",
        "wrangler": "^4.92.0"
    },
    "keywords": [
        "mihon",
        "aniyomi",
        "extensions",
        "manga",
        "anime"
    ]
}
