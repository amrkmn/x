---
import SearchApp from '$lib/components/SearchApp.svelte';
import { loadAppData } from '$lib/data';
import { withSiteUrl } from '$lib/site';
import Base from '../layouts/Base.astro';

const data = loadAppData();
---

<Base
    data={data}
    title="Search Extensions - Mihon & Aniyomi"
    description="Search and filter Mihon and Aniyomi extensions by name, source, language, and category. Find exactly what you need."
    canonical={withSiteUrl('/search')}
>
    <SearchApp client:only="svelte" {data} />
</Base>
